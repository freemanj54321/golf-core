rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Golf data is read-only for authenticated users of consumer apps via service account.
    // Admin app users can read/write via Firebase Auth (golf-core project auth).
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
